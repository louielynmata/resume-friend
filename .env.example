# ── Personal ─────────────────────────────────────────────────────────────────
# Used in output filenames: {OWNER_NAME}_Resume_{Position}.docx
OWNER_NAME=
OWNER_EMAIL=

# ── AI Providers ─────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama runs locally — check your installed models with: ollama list
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Model overrides (optional — defaults shown)
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# ── Notion ────────────────────────────────────────────────────────────────────
# Setup steps:
# 1. Go to https://www.notion.so/my-integrations → New Integration → copy the token
# 2. Create a new Notion database page (or use existing), share it with your integration
# 3. Copy the database ID from the URL: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Relative to project root. Change only if you want outputs/models elsewhere.
MODEL_FILES_DIR=./model_files
OUTPUT_DIR=./outputs

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173
