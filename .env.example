# ── Personal ─────────────────────────────────────────────────────────────────
# Exact applicant display name used in document headers, sign-offs, and filenames.
OWNER_NAME="Your Name"
OWNER_EMAIL=

# ── AI Providers ─────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama runs locally — check your installed models with: ollama list
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# Model overrides (optional — defaults shown)
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Independent QA reviewer/fixer
# "same" uses the writer provider selected in the UI. Or set claude/openai/ollama.
QA_ENABLED=true
QA_PROVIDER=same
# Additional corrective retries after the mandatory independent review.
QA_MAX_REPAIRS=2
QA_LANGUAGE=en-CA
QA_FAIL_OPEN=false
QA_VISUAL_ENABLED=true
QA_RESUME_MAX_PAGES=2
QA_COVER_LETTER_MAX_PAGES=1

# ── Notion ────────────────────────────────────────────────────────────────────
# Setup steps:
# 1. Go to https://www.notion.so/my-integrations → New Integration → copy the token
# 2. Create a new Notion database page (or use existing), share it with your integration
# 3. Copy the database ID from the URL: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Relative to project root. Change only if you want outputs/models elsewhere.
APP_MODEL_FILES_DIR=./prompts
MODEL_FILES_DIR=./models_personal
OUTPUT_DIR=./outputs
QA_TEMP_DIR=./tmp/pdfs

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173
